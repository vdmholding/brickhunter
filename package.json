{
  "name": "brickhunter",
  "version": "0.1.0",
  "description": "Lego set price search and comparison agent across eBay, BrickLink, LEGO.com, and BrickEconomy",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "setup-db": "bash scripts/setup-db.sh",
    "mcp": "node src/mcp.js",
    "test": "node --test --test-concurrency=1 test/sources/index.test.js test/db/queries/sets.test.js test/db/queries/listings.test.js test/db/queries/monitors.test.js test/api/routes.test.js"
  },
  "keywords": [
    "lego",
    "bricklink",
    "ebay",
    "price-comparison",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.0",
    "express": "^5.1.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "^24.41.0",
    "puppeteer-core": "^24.41.0",
    "zod": "^4.3.6"
  }
}
