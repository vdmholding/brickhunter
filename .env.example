# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://user:password@localhost:5432/brickhunter

# eBay API (https://developer.ebay.com/)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# BrickLink API (https://www.bricklink.com/v3/api.page)
BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_TOKEN=
BRICKLINK_TOKEN_SECRET=

# Rebrickable API (https://rebrickable.com/api/)
REBRICKABLE_API_KEY=

# LLM (fill in whichever provider you use)
LLM_PROVIDER=          # anthropic | openai
LLM_API_KEY=
LLM_MODEL=
